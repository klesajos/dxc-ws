{
  "extraKnownMarketplaces": {
    "dxc-ws": {
      "source": {
        "source": "github",
        "repo": "klesajos/dxc-ws"
      }
    }
  },
  "enabledPlugins": {
    "2048-dev@dxc-ws": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/format-cpp.sh"
          }
        ]
      }
    ]
  }
}
